# Shopee Affiliate API Configuration
# Copy this file to .env and fill in your credentials

# Get your API credentials from: https://affiliate.shopee.vn/developer
SHOPEE_API_KEY=your_api_key_here
SHOPEE_API_SECRET=your_api_secret_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Optional: Use test environment
# SHOPEE_API_URL=https://open-api.test-stable.affiliate.shopee.vn/graphql

# Database (if needed)
# DATABASE_URL=mongodb://localhost:27017/shopee_affiliate
# REDIS_URL=redis://localhost:6379

# Webhook Secret (if using webhooks)
# WEBHOOK_SECRET=your_webhook_secret
