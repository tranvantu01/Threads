{
  "manifest_version": 3,
  "name": "Threads Profile Data Downloader Pro",
  "version": "2.0.0",
  "description": "Download multiple Threads profiles, convert Shopee affiliate links, export to Excel, schedule downloads",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://www.threads.com/*"
  ],
  "action": {
    "default_popup": "popup-v2.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background-v2.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.threads.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
