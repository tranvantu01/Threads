# Shopee Automation Configuration

# Server
PORT=3000
NODE_ENV=production

# Shopee Account (Affiliate Dashboard)
SHOPEE_USERNAME=your_shopee_email@example.com
SHOPEE_PASSWORD=your_password_here

# Shopee Affiliate ID
SHOPEE_AFFILIATE_ID=17357490088

# Puppeteer Settings
HEADLESS=true
SLOW_MO=0

# Security (Optional)
API_KEY=your_secret_api_key_here

# Rate Limiting (requests per minute)
RATE_LIMIT=30
