# Shopee Affiliate Credentials
SHOPEE_USERNAME=your_email@gmail.com
SHOPEE_PASSWORD=your_password
SHOPEE_AFFILIATE_ID=17357490088

# Server Configuration
PORT=3000

# Puppeteer Settings
HEADLESS=true
SLOWMO=100
TIMEOUT=30000

# Notes:
# - SHOPEE_USERNAME: Email hoặc phone đăng nhập Shopee Affiliate
# - SHOPEE_PASSWORD: Mật khẩu tài khoản
# - SHOPEE_AFFILIATE_ID: Affiliate ID của bạn (mặc định: 17357490088)
# - HEADLESS: true = chạy ngầm, false = hiện browser (để debug)
# - SLOWMO: Delay giữa các actions (ms), càng cao càng giống người thật
# - TIMEOUT: Timeout cho mỗi action (ms)
